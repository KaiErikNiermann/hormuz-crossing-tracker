#!/bin/sh

echo "==> Pre-push: checking TypeScript..."
cd site && pnpm run typecheck || exit 1

echo "==> Pre-push: building frontend..."
pnpm run build || exit 1
cd ..

echo "==> Pre-push: checking Python syntax..."
python -c "
import py_compile, sys, pathlib
errors = []
for f in pathlib.Path('.').rglob('*.py'):
    if 'node_modules' in str(f) or '.cache' in str(f):
        continue
    try:
        py_compile.compile(str(f), doraise=True)
    except py_compile.PyCompileError as e:
        errors.append(str(e))
if errors:
    print('Python syntax errors:')
    for e in errors:
        print(f'  {e}')
    sys.exit(1)
" || exit 1

echo "==> Pre-push: verifying data files exist..."
if [ ! -f site/data/vessels_timeline.json ]; then
  echo "ERROR: site/data/vessels_timeline.json missing"
  exit 1
fi

echo "==> Pre-push: all checks passed"
